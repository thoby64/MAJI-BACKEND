# ============================================================
# HydraNet Backend - Environment Configuration
# Copy this file to .env and fill in your configuration
# ============================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Database Configuration
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://hydranet_user:hydranet_password@localhost:5432/hydranet

# Security Configuration
SECRET_KEY=your-super-secret-key-change-in-production-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend Configuration (IMPORTANT for CORS)
# This URL is used to allow requests from the frontend and generate frontend links
FRONTEND_URL=http://localhost:3000

# API Configuration
API_PREFIX=/api

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Optional one-time historical DUWASA import on startup
LEGACY_DUWASA_IMPORT_ON_STARTUP=false
# Optional override. Leave blank to use the CSV committed inside the backend folder.
LEGACY_DUWASA_IMPORT_CSV_PATH=
LEGACY_DUWASA_IMPORT_STRICT=false
# LEGACY_DUWASA_IMPORT_LIMIT=50
